page { background: #080808; color: #fff; font-family: -apple-system, sans-serif; }
.container { padding-bottom: 100rpx; }

/* Hero */
.hero { padding: 64rpx 36rpx 44rpx; display: flex; flex-direction: column; }
.hero-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; }
.hero-badge {
  width: 80rpx; height: 80rpx; border-radius: 22rpx;
  border: 1rpx solid; background: rgba(255,255,255,0.04);
  display: flex; align-items: center; justify-content: center;
}
.hero-logo { font-size: 46rpx; }
.barcode-toggle { padding: 14rpx 24rpx; border-radius: 12rpx; background: #111; }
.barcode-toggle-text { font-size: 22rpx; font-weight: 600; }
.hero-name { display: block; font-size: 52rpx; font-weight: 800; color: #fff; letter-spacing: -1.5rpx; }
.hero-level { display: block; font-size: 22rpx; color: #333; margin-top: 8rpx; font-weight: 300; letter-spacing: 1rpx; }
.hero-points-pill {
  display: inline-flex; align-items: baseline;
  border-radius: 14rpx; padding: 14rpx 24rpx;
  margin-top: 24rpx; align-self: flex-start;
}
.hero-points { font-size: 40rpx; font-weight: 900; letter-spacing: -1rpx; }
.hero-pts-label { font-size: 20rpx; color: #333; margin-left: 8rpx; font-weight: 300; }

/* Progress bar */
.progress-section { margin-top: 28rpx; }
.progress-label-row { display: flex; justify-content: space-between; margin-bottom: 10rpx; }
.progress-label { font-size: 20rpx; color: #333; font-weight: 400; }
.progress-track { height: 6rpx; background: #1a1a1a; border-radius: 3rpx; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 3rpx; transition: width 0.6s; }

/* Barcode */
.barcode-panel {
  margin-top: 28rpx; background: #0d0d0d;
  border-radius: 16rpx; padding: 28rpx;
  display: flex; flex-direction: column; align-items: center;
}
.barcode-label { font-size: 18rpx; color: #333; letter-spacing: 2rpx; margin-bottom: 20rpx; }
.barcode-lines { display: flex; align-items: flex-end; gap: 3rpx; margin-bottom: 16rpx; height: 56rpx; }
.barcode-line { border-radius: 1rpx; }
.barcode-number { font-size: 22rpx; color: #444; letter-spacing: 3rpx; font-weight: 500; }

/* Merchant view */
.merchant-view-btn { margin-top: 28rpx; align-self: flex-start; }
.merchant-view-text { font-size: 22rpx; font-weight: 600; letter-spacing: 0.5rpx; }

/* Divider */
.divider { height: 1rpx; margin: 0 36rpx 40rpx; }

/* Deals */
.deals-list { padding: 0 36rpx; }
.list-heading { display: block; font-size: 20rpx; color: #2e2e2e; letter-spacing: 3rpx; font-weight: 500; margin-bottom: 24rpx; }
.deal-card { background: #111; border-radius: 20rpx; padding: 28rpx; margin-bottom: 16rpx; }
.deal-row-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.deal-tag { border-radius: 7rpx; padding: 7rpx 16rpx; display: inline-block; }
.deal-tag-text { font-size: 18rpx; font-weight: 600; }
.deal-expiry { font-size: 18rpx; color: #2e2e2e; }
.deal-title { display: block; font-size: 28rpx; font-weight: 700; color: #f0f0f0; line-height: 1.35; margin-bottom: 10rpx; }
.deal-desc { display: block; font-size: 22rpx; color: #444; line-height: 1.6; font-weight: 300; margin-bottom: 24rpx; }
.deal-actions { display: flex; align-items: center; gap: 16rpx; }
.claim-btn { border-radius: 12rpx; padding: 18rpx 32rpx; }
.claim-btn-text { font-size: 24rpx; font-weight: 700; color: #000; }
.save-btn { padding: 18rpx 24rpx; }
.save-btn-text { font-size: 22rpx; font-weight: 600; }