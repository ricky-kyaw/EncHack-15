page {
  background: #080808;
  color: #ffffff;
  font-family: -apple-system, sans-serif;
}

.container {
  padding-bottom: 100rpx;
}

.hero {
  padding: 64rpx 36rpx 44rpx;
  display: flex;
  flex-direction: column;
}

.hero-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  border: 1rpx solid;
  background: rgba(255,255,255,0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.hero-logo {
  font-size: 46rpx;
}

.hero-name {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: -1.5rpx;
  line-height: 1.1;
}

.hero-level {
  display: block;
  font-size: 22rpx;
  color: #3a3a3a;
  margin-top: 8rpx;
  font-weight: 300;
  letter-spacing: 1rpx;
}

.hero-points-pill {
  display: inline-flex;
  align-items: baseline;
  border-radius: 14rpx;
  padding: 14rpx 24rpx;
  margin-top: 26rpx;
  align-self: flex-start;
}

.hero-points {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.hero-pts-label {
  font-size: 20rpx;
  color: #3a3a3a;
  margin-left: 8rpx;
  font-weight: 300;
}

.divider {
  height: 1rpx;
  margin: 0 36rpx 40rpx;
}

.deals-list {
  padding: 0 36rpx;
}

.list-heading {
  display: block;
  font-size: 20rpx;
  color: #2e2e2e;
  letter-spacing: 3rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.deal-card {
  background: #111111;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}

.deal-row-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.deal-tag {
  border-radius: 7rpx;
  padding: 7rpx 16rpx;
  display: inline-block;
}

.deal-tag-text {
  font-size: 19rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

.deal-expiry {
  font-size: 19rpx;
  color: #2e2e2e;
}

.deal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #f0f0f0;
  letter-spacing: -0.2rpx;
  line-height: 1.35;
  margin-bottom: 10rpx;
}

.deal-desc {
  display: block;
  font-size: 22rpx;
  color: #4a4a4a;
  line-height: 1.6;
  font-weight: 300;
  margin-bottom: 24rpx;
}

.claim-btn {
  border-radius: 14rpx;
  padding: 22rpx;
  text-align: center;
}

.claim-btn-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #000000;
  letter-spacing: 0.3rpx;
}