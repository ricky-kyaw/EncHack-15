page { background: #080808; font-family: -apple-system, sans-serif; }
.container { padding: 64rpx 36rpx 100rpx; }

.page-title { display: block; font-size: 48rpx; font-weight: 800; color: #fff; letter-spacing: -1rpx; margin-bottom: 10rpx; }
.page-sub { display: block; font-size: 24rpx; color: #333; margin-bottom: 40rpx; }

.search-bar {
  display: flex; align-items: center;
  background: #111; border-radius: 16rpx;
  padding: 22rpx 28rpx; margin-bottom: 36rpx;
  border: 1rpx solid #1e1e1e;
}
.search-icon { font-size: 30rpx; color: #333; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 26rpx; color: #fff; background: transparent; }
.search-placeholder { color: #2e2e2e; }

.merchant-list { display: flex; flex-direction: column; gap: 0; }

.merchant-row {
  display: flex; align-items: flex-start;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #111;
}

.merchant-logo-wrap {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx; margin-top: 4rpx;
}
.merchant-logo { font-size: 36rpx; }

.merchant-info { flex: 1; margin-right: 16rpx; }
.merchant-name { display: block; font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; }
.merchant-category { display: block; font-size: 20rpx; color: #333; margin-bottom: 8rpx; letter-spacing: 0.5rpx; }
.merchant-desc { display: block; font-size: 22rpx; color: #3a3a3a; line-height: 1.5; margin-bottom: 8rpx; }
.merchant-deals { display: block; font-size: 20rpx; font-weight: 600; }

.add-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  border: 1rpx solid; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  margin-top: 10rpx;
}
.add-btn-added { background: #111; }
.add-btn-text { font-size: 28rpx; font-weight: 700; }

.custom-cta { padding: 40rpx 0 0; }
.custom-cta-text { font-size: 24rpx; color: #333; font-weight: 500; }